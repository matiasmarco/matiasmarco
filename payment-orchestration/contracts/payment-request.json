{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/contracts/payment-request.json",
  "title": "PaymentRequest",
  "type": "object",
  "required": [
    "paymentId",
    "merchantId",
    "idempotencyKey",
    "amount",
    "currency",
    "country",
    "customer",
    "paymentMethod",
    "captureMode"
  ],
  "properties": {
    "paymentId": { "type": "string", "pattern": "^[a-zA-Z0-9_-]{8,64}$" },
    "merchantId": { "type": "string" },
    "idempotencyKey": { "type": "string", "minLength": 8, "maxLength": 128 },
    "amount": {
      "type": "object",
      "required": ["value", "currencyExponent"],
      "properties": {
        "value": { "type": "integer", "minimum": 1 },
        "currencyExponent": { "type": "integer", "minimum": 0, "maximum": 3 }
      }
    },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "country": { "type": "string", "minLength": 2, "maxLength": 2 },
    "captureMode": { "type": "string", "enum": ["AUTO", "MANUAL"] },
    "customer": {
      "type": "object",
      "required": ["customerId", "email"],
      "properties": {
        "customerId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "ipAddress": { "type": "string" }
      }
    },
    "paymentMethod": {
      "type": "object",
      "required": ["type", "token"],
      "properties": {
        "type": { "type": "string", "enum": ["CARD", "WALLET", "BANK_TRANSFER"] },
        "token": { "type": "string" },
        "requires3ds": { "type": "boolean" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "additionalProperties": false
}
